{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "create-react-app",
  "buildCommand": "yarn build",
  "outputDirectory": "build",
  "installCommand": "yarn install",
  "redirects": [
    {
      "source": "/schemaforge/:match(.*)",
      "has": [{ "type": "query", "key": "status", "value": "success" }],
      "destination": "https://medspa-schemaforge.vercel.app/:match?status=success",
      "permanent": false
    },
    {
      "source": "/schemaforge",
      "has": [{ "type": "query", "key": "status", "value": "success" }],
      "destination": "https://medspa-schemaforge.vercel.app/?status=success",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/schemaforge", "destination": "https://medspa-schemaforge.vercel.app/" },
    { "source": "/schemaforge/", "destination": "https://medspa-schemaforge.vercel.app/" },
    { "source": "/schemaforge/:match*", "destination": "https://medspa-schemaforge.vercel.app/:match*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/leads.js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
